{
 "version": 2,
 "routes": [
  {
   "src": "/",
   "dest": "/index.html"
  },
  {
   "src": "/(.*)",
   "dest": "/$1"
  }
 ],
 "headers": [
  {
   "source": "/(.*)\\.html",
   "headers": [
    {
     "key": "Content-Type",
     "value": "text/html; charset=UTF-8"
    }
   ]
  },
  {
   "source": "/(.*)\\.txt",
   "headers": [
    {
     "key": "Content-Type",
     "value": "text/plain; charset=UTF-8"
    }
   ]
  }
 ]
}